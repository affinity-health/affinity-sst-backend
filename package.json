  "dependencies": {
    "@affinity-health/sdk": "link:@affinity-health/sdk",
    "@orpc/openapi": "^1.14.8",
    "@orpc/server": "^1.14.8",
    "@orpc/zod": "^1.14.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@types/bun": "latest",
    "@typescript/native-preview": "latest"
  }
}
